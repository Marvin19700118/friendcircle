{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@domain/*": [
        "./src/domain/*"
      ],
      "@data/*": [
        "./src/data/*"
      ],
      "@services/*": [
        "./src/services/*"
      ],
      "@platform/*": [
        "./src/platform/*"
      ],
      "@ui/*": [
        "./src/ui/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}